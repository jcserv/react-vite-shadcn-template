{
  "name": "react-vite-shadcn-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "prettier . --write && eslint . --fix",
    "prepare": "husky",
    "test": "pnpm test:types && pnpm test:unit && pnpm test:cypress:ci",
    "test:unit": "vitest run",
    "test:cypress:ci": "cypress run --component --browser chrome",
    "test:cypress:dev": "cypress open --component --browser chrome",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-router": "1.163.3",
    "class-variance-authority": "^0.5.3",
    "clsx": "^1.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^1.14.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.18",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.16.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "1.163.3",
      "@tanstack/router-devtools": "1.167.0",
      "@tanstack/router-plugin": "1.168.18",
      "@tanstack/router-core": "1.163.3",
      "@tanstack/react-router-devtools": "1.163.3",
      "@tanstack/router-devtools-core": "1.163.3",
      "@tanstack/router-generator": "1.163.3"
    }
  }
